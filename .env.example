# Variables de entorno para Ventas Ecommerce
# Copia este archivo a .env y rellena con tus valores reales
# ¡IMPORTANTE: .env está en .gitignore y NO se sube a GitHub!

# Configuración de Base de Datos
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=ventas_ecommerce
DB_PORT=5432

# Configuración opcional
DEBUG=False
LOG_LEVEL=INFO
